{
  "name": "kairos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:baseline": "pnpm --filter server db:baseline",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "db:init": "node scripts/db-init.mjs",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:status": "pnpm --filter server db:status",
    "db:migrate-duration": "node scripts/db-migrate-duration.mjs",
    "db:fix-permissions": "node scripts/db-fix-permissions.mjs",
    "build": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter client build",
    "test": "pnpm --filter server test",
    "test:watch": "pnpm --filter server test:watch",
    "test:ui": "node scripts/run-ui-regression.mjs",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "typecheck": "pnpm -r typecheck",
    "prepare": "git rev-parse --git-dir 2>/dev/null && lefthook install || true"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "pg": "^8.13.1",
    "playwright": "^1.58.2",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
